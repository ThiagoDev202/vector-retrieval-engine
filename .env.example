APP_ENV=dev

# Modelo de embeddings (HuggingFace). Multilíngue, 384 dimensões.
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384

# Diretórios (dentro do container). Respeitam o volume nomeado do compose.
INDEX_DIR=/app/data/index
CORPUS_DIR=/app/data/raw

# Chunking por tokens do tokenizer do modelo.
CHUNK_SIZE=256
CHUNK_OVERLAP=32

# Busca.
DEFAULT_TOP_K=5

# Se true e o índice estiver vazio no startup, ingere CORPUS_DIR automaticamente.
BOOTSTRAP_ON_STARTUP=true
